#: easy-auto-reload.php:296
msgid "INFO:"
msgstr "INFO:"

#: easy-auto-reload.php:295
msgid "Enable auto refresh globally on the entire site."
msgstr "Schakel automatisch verversen globaal in op de hele site."

#: easy-auto-reload.php:529
msgid "Refresh interval in minutes:"
msgstr "Verversen interval in minuten:"

#: easy-auto-reload.php:512
